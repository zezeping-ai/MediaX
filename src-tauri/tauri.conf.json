{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mediax",
  "version": "0.1.1",
  "identifier": "com.zezeping.mediax",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "mediax",
        "width": 800,
        "height": 600,
        "decorations": true,
        "transparent": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$DESKTOP/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**",
          "$VIDEO/**",
          "$TEMP/**"
        ]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["mediax"]
      }
    },
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJERjlERTQ2NkVERDM4NTQKUldSVU9OMXVSdDc1dlZ6SUExSk5BaGRWZ3JRNGFMbjVqNUkvcTJlbThUeDc3aVpoNEdJbHFROUQK",
      "endpoints": [
        "https://github.com/zezeping-ai/MediaX/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
